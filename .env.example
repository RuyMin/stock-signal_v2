# stock-signal 환경변수 템플릿
# 실제 값은 .env.dev / .env.staging / .env.prod 로 분리, Git에 커밋 금지.

# === 환경 식별 ===
VIBE_ENV=dev                              # dev | staging | prod
TZ=Asia/Seoul

# === PostgreSQL ===
POSTGRES_USER=stock
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=stock_signal_dev              # _dev | _staging | _prod
DATABASE_URL=postgresql+asyncpg://stock:CHANGE_ME@postgres:5432/stock_signal_dev

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# === Backend (FastAPI) ===
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=DEBUG                   # DEBUG | INFO | WARNING
CORS_ORIGINS=*                            # *(dev) | 도메인 한정(staging/prod)

# === 한국투자증권 OpenAPI ===
KIS_APP_KEY=CHANGE_ME
KIS_APP_SECRET=CHANGE_ME
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_ACCOUNT_NO=                                       # 조회용 계좌 (필요 시)
# 신호 수집 시장 범위: 0000(전체) | 0001(코스피) | 1001(코스닥)
KIS_SIGNAL_MARKET_SCOPE=0000
# TR_ID — KIS가 변경할 경우 또는 모의(데모)에서 다른 ID 쓸 때 오버라이드
KIS_TR_FOREIGN_INSTITUTION_TOTAL=FHPTJ04400000        # 외국인기관 매매가집계 [HTS 0440]
KIS_TR_SEARCH_STOCK_INFO=CTPF1002R                    # 주식기본조회 (종목명 lookup)

# === OpenAI (CrewAI) ===
# OPENAI_MODEL_NAME은 CrewAI/LiteLLM이 자동 인식하는 환경변수.
# OPENAI_MODEL은 인식되지 않아 기본 gpt-4로 fallback → 비용 위험.
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL_NAME=gpt-4o-mini

# === Telegram ===
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_AUTHORIZED_CHAT_ID=CHANGE_ME     # 단일 사용자 chat_id

# === Scheduler ===
SCHEDULE_HOUR=15                          # 매일 트리거 시각 (Asia/Seoul)
SCHEDULE_MINUTE=35

# === Grafana ===
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# === GitHub Container Registry (staging/prod 오버라이드용) ===
# 형식: ghcr.io/<owner>/<repo>
# 예시: ghcr.io/minsh1731/stock-signal
# CI/CD에서는 ${{ github.repository }}로 자동 치환되므로 GitHub Actions에는 불필요.
# docker-compose.{staging,prod}.yml에서 image: ${GHCR_IMAGE_PREFIX}/{service}:tag 형태로 참조.
GHCR_IMAGE_PREFIX=ghcr.io/CHANGE_ME/CHANGE_ME
IMAGE_TAG=latest                          # latest | commit SHA
